# Environment Configuration
# Copy this file to .env and update with your values

# Environment: development or production
ENVIRONMENT=development

# Database URLs (required)
DEV_DATABASE_URL=postgresql://postgres:1234@localhost:5433/postgres
PROD_DATABASE_URL=postgresql://postgres:1234@localhost:5432/postgres

# Optional: Override with a custom DATABASE_URL
# DATABASE_URL=postgresql://postgres:1234@localhost:5433/postgres

# OpenAI API Key (if needed)
# PERSONAL_OPENAI_API_KEY=your_api_key_here
